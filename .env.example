# Keeper 环境变量配置示例
# 复制此文件为 .env 并填入实际值

# 数据库配置
DATABASE_URL=sqlite:///./keeper.db

# 安全密钥（使用 openssl rand -hex 32 生成）
SECRET_KEY=your_secret_key_here_use_openssl_rand_to_generate

# API 配置
API_HOST=127.0.0.1
API_PORT=8443
API_VERSION=v1

# HTTPS 证书路径
SSL_KEYFILE=./certs/localhost-key.pem
SSL_CERTFILE=./certs/localhost.pem

# CORS 允许的来源（Firefox 扩展 ID）
ALLOWED_ORIGINS=moz-extension://your-extension-id-here

# 自定义认证头密钥（使用 openssl rand -base64 32 生成）
X_KEEPER_SECRET=your_preshared_secret_here

# 开发模式
DEBUG=true

# 日志级别（DEBUG, INFO, WARNING, ERROR）
LOG_LEVEL=INFO

# JWT 配置
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# Argon2id 参数（KDF）
ARGON2_MEMORY_COST=65536  # 64MB
ARGON2_TIME_COST=3
ARGON2_PARALLELISM=4
